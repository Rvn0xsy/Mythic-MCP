# Mythic MCP server config
# Point this at a Mythic instance you are authorized to use.

MYTHIC_URL=https://127.0.0.1:7443
# Choose ONE auth method:
# MYTHIC_API_TOKEN=
MYTHIC_USERNAME=mythic_admin
MYTHIC_PASSWORD=

# Common local-dev options
MYTHIC_SSL=true
MYTHIC_SKIP_TLS_VERIFY=true

# MCP HTTP transport (host-accessible port)
MCP_HTTP_PORT=3333

# Optional
LOG_LEVEL=info
TIMEOUT=30s
